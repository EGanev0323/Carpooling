# Database
DB_URL=jdbc:postgresql://postgres:5432/carpooling
DB_USER=carpooling
DB_PASSWORD=change_me_strong_password

# JWT — минимум 64 знака, генерирай с: openssl rand -hex 64
JWT_SECRET=change_this_to_a_random_64_char_secret_string_do_not_use_in_prod_00

# Cloudflare Turnstile
# Тест ключове (винаги минават): site=1x00000000000000000000AA, secret=1x0000000000000000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA
TURNSTILE_ENABLED=false

# CORS — фронтенд origin
CORS_ALLOWED_ORIGIN=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# SMTP — използвай Mailtrap за dev
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Seed данни (само dev)
SEED_ENABLED=true

# PostgreSQL (за docker-compose)
POSTGRES_DB=carpooling
POSTGRES_USER=carpooling
POSTGRES_PASSWORD=change_me_strong_password
